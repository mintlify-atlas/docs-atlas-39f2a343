  "keyFeatures": [
    "Server-side 3D BlockBench model rendering using item display entities",
    "Runtime animation playback with per-player animation support",
    "Auto-generating resource packs from .bbmodel files",
    "Custom hitbox creation and interaction handling",
    "12-limb player model animation support",
    "Entity-synced model tracking",
    "High-performance design optimized for large servers",
    "Multi-platform support (Bukkit, Paper, Spigot, Folia, Fabric)"
  ],
